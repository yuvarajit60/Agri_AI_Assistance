# Copy to .env and fill in real values as each integration is wired up.
# Nothing here is required for local dev with docker-compose — all
# services run against mock/estimated providers until these are set.

# Farm Registry
DATABASE_URL=postgresql+psycopg2://agri:agri@localhost:5432/agri_farm_registry

# Weather service (not yet consumed — MockWeatherProvider is hardcoded until this is wired in)
OPENWEATHER_API_KEY=
IMD_API_KEY=

# GIS service (not yet consumed — MockElevationProvider is hardcoded until this is wired in)
GOOGLE_MAPS_API_KEY=
GOOGLE_EARTH_ENGINE_SERVICE_ACCOUNT_JSON=

# Soil service (not yet consumed — SatelliteEstimatedSoilProvider is hardcoded until this is wired in)
SOIL_HEALTH_CARD_API_KEY=

# AI Advisor / AI Chat (Phase 4 — services not yet built) and disease_kb's
# photo-based detection (services/disease_kb — knowledge-base text search
# works without this; only the vision step needs it)
ANTHROPIC_API_KEY=

# Gateway upstream service URLs (defaults match docker-compose service names)
SOIL_SERVICE_URL=http://soil:8000
WEATHER_SERVICE_URL=http://weather:8000
CROP_SERVICE_URL=http://crop_recommendation:8000
GIS_SERVICE_URL=http://gis:8000
FARM_REGISTRY_URL=http://farm_registry:8000
DISEASE_KB_SERVICE_URL=http://disease_kb:8000
